# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────────
/coverage

# ── Next.js build output ──────────────────────────────────────────
/.next/
/out/
/build

# ── Sanity Studio build output ────────────────────────────────────
/dist
/.sanity

# ── Misc ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.key

# ── Debug logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Environment / secrets (NEVER commit these) ────────────────────
# .env.local.example is intentionally NOT listed here — it is a safe template
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging

# ── Vercel ────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── IDE / Editor ──────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
.cache/
